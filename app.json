{
  "expo": {
    "name": "vero",
    "slug": "vero",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/image.png",
    "scheme": "vero",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1c1917",
        "foregroundImage": "./assets/image.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "server",
      "favicon": "./assets/image.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
"image": "./assets/image.png",
        "imageWidth": 200,
        "resizeMode": "contain",
        "backgroundColor": "#1c1917",
        "dark": {
          "backgroundColor": "#1c1917"
        }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
